{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClipboardX",
  "version": "0.1.4",
  "identifier": "com.clipboardx.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev-vite",
    "beforeBuildCommand": "npm run build-vite"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "ClipboardX",
        "width": 420,
        "height": 600,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM4M0VBQzVERTg2RDUxQUQKUldTdFVXM29YYXcreU8xSldWK1piSU5DeTh5U3dEQkJFbEx4NER3TUovbmg0MDlOMVY0NUdpdjYK",
      "endpoints": [
        "https://github.com/Murphycx94/clipboard-x/releases/latest/download/latest.json"
      ]
    }
  }
}
